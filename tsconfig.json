{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@api/*":         ["src/api/*"],
      "@controllers/*": ["src/controllers/*"],
      "@models/*":      ["src/models/*"],
      "@utils/*":       ["src/utils/*"],
      "@config/*":      ["src/config/*"],
      "@fixtures/*":    ["src/fixtures/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}